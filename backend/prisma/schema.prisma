generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model News {
  id          String   @id @default(cuid())
  title       String
  excerpt     String?
  content     String?
  image       String?
  source      String
  url         String   @unique
  publishedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([publishedAt])
  @@index([source])
}
